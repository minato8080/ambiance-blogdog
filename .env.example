# OpenAI API キー（必須）
OPENAI_API_KEY=sk-...

# 管理系エンドポイントの認証キー（必須）
API_KEY=your-secret-api-key

# サーバー設定
PORT=8080

# --- Discovery クローラー ---
CRAWL_INTERVAL_MIN=360          # 実行間隔（分）
TFIDF_SAMPLE_SIZE=500           # TF-IDF コーパスサイズ（記事数）
TFIDF_KEYWORD_COUNT=20          # TF-IDF 抽出キーワード数

# --- Indexer クローラー ---
SYNC_INTERVAL_MIN=60            # 実行間隔（分）
INDEX_BATCH_SIZE=50             # 1回あたりの処理ブログ数
INDEX_MAX_ERROR_COUNT=3         # error 状態に移行するエラー連続回数
MAX_ARTICLES_PER_BLOG=5        # 1ブログあたりの上限記事数

# --- Syncer クローラー ---
SYNC_STALENESS_DAYS=30          # 差分チェック対象とする最終同期からの経過日数
SYNC_BATCH_SIZE=50              # 1回あたりの処理ブログ数
SYNC_MAX_ERROR_COUNT=3          # error 状態に移行するエラー連続回数

# --- Historical クローラー ---
HISTORICAL_INTERVAL_MIN=1440    # 実行間隔（分）
CRAWL_DATE_FROM=2010-01-01      # 過去クロールの対象開始日
CRAWL_DATE_TO=2025-01-01        # 過去クロールの対象終了日（デフォルト: 1年前）
HISTORICAL_BOOKMARK_MAX=200     # ブックマーク数検索の上限（0〜N のランダム）
HISTORICAL_DATE_WINDOW_DAYS=7   # 日付範囲検索のウィンドウ幅（日）
HISTORICAL_DATE_USERS_MAX=2     # 日付範囲検索のブックマーク数上限（0〜N）

# --- Recent クローラー ---
RECENT_INTERVAL_MIN=30          # 実行間隔（分）

# OpenAI 並列数
CRAWL_CONCURRENCY=5

# CORS（カンマ区切りで複数指定可、* はワイルドカード）
CORS_ALLOWED_ORIGINS=*

# ログレベル: debug / info / warn / error
LOG_LEVEL=info
