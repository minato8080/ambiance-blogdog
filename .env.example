# OpenAI API キー（必須）
OPENAI_API_KEY=sk-...

# 管理系エンドポイントの認証キー（必須）
API_KEY=your-secret-api-key

# サーバー設定
PORT=8080

# クローラー設定
CRAWL_INTERVAL_MIN=360
SYNC_INTERVAL_MIN=60
SYNC_STALENESS_DAYS=30
CRAWL_CONCURRENCY=5
MAX_ARTICLES_PER_BLOG=5
CRAWL_DATE_FROM=2010-01-01

# CORS（カンマ区切りで複数指定可、* はワイルドカード）
CORS_ALLOWED_ORIGINS=*

# ログレベル: debug / info / warn / error
LOG_LEVEL=info
